---
const REPO = 'https://github.com/Marcosreuquen/typemark';
const RELEASES = `${REPO}/releases/latest`;

const features = [
  {
    title: 'Live, WYSIWYG markdown',
    body: 'Milkdown/ProseMirror render your formatting as you type — no split-pane preview, no context switch.',
  },
  {
    title: 'An agent lives in your editor',
    body: 'A real integrated terminal, backed by a native shell. Run Claude Code or any other CLI agent next to the note it’s working on.',
  },
  {
    title: 'Vim mode, done properly',
    body: 'Normal / Insert / Visual, hjkl, word and block motions, yank/delete/paste, and your own custom keymaps.',
  },
  {
    title: 'Git without leaving the page',
    body: 'Stage, commit, and switch branches from a panel that lives right in the status bar.',
  },
  {
    title: 'Private by default, when you want it',
    body: 'Touch ID-locked vaults and notes, encrypted at rest with the OS keychain — not a cloud account.',
  },
  {
    title: 'Tuned for long writing sessions',
    body: 'Eleven themes, ten fonts, adjustable size, wide-block mode for tables and diagrams.',
  },
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<title>TypeMark — the markdown IDE for the agentic era</title>
		<meta
			name="description"
			content="TypeMark is a fast, native markdown editor for macOS with an integrated terminal, Vim mode, and Git built in — so your writing and your coding agents live in the same window."
		/>
		<meta property="og:title" content="TypeMark — the markdown IDE for the agentic era" />
		<meta
			property="og:description"
			content="A fast, native markdown editor with an integrated terminal, Vim mode, and Git built in."
		/>
		<meta property="og:type" content="website" />
		<meta name="generator" content={Astro.generator} />
	</head>
	<body>
		<header class="nav">
			<a class="nav-brand" href="#top">
				<span class="nav-mark">T</span>
				TypeMark
			</a>
			<nav class="nav-links">
				<a href="#features">Features</a>
				<a href="#download">Download</a>
				<a href={REPO}>GitHub</a>
			</nav>
		</header>

		<main>
			<section class="hero" id="top">
				<p class="eyebrow">For macOS &middot; free &middot; open source</p>
				<h1>The markdown editor built for the <em>agentic era</em>.</h1>
				<p class="lede">
					TypeMark is a fast, native writing surface with a real terminal built in —
					so your notes and your coding agents share the same window, not two.
				</p>
				<div class="cta-row">
					<a class="button button-primary" href={RELEASES}>Download for Mac</a>
					<a class="button button-ghost" href={REPO}>View on GitHub</a>
				</div>

				<div class="mockup" aria-hidden="true">
					<div class="mockup-titlebar">
						<span class="dot dot-red"></span>
						<span class="dot dot-yellow"></span>
						<span class="dot dot-green"></span>
						<span class="mockup-path">notes / roadmap.md</span>
					</div>
					<div class="mockup-body">
						<div class="mockup-editor">
							<p class="mockup-h1"># Q3 roadmap</p>
							<p>- [x] Ship the integrated terminal</p>
							<p>- [ ] <span class="mockup-cursor">Wire up the release pipeline</span></p>
						</div>
						<div class="mockup-terminal">
							<p><span class="mockup-prompt">➜</span> claude</p>
							<p class="mockup-dim">Reading roadmap.md…</p>
							<p class="mockup-dim">Drafting the GitHub Actions workflow<span class="mockup-blink">▍</span></p>
						</div>
					</div>
				</div>
			</section>

			<section class="features" id="features">
				<h2>Everything a writing tool needs. Nothing it doesn't.</h2>
				<div class="feature-grid">
					{features.map((f) => (
						<article class="feature-card">
							<h3>{f.title}</h3>
							<p>{f.body}</p>
						</article>
					))}
				</div>
			</section>

			<section class="download" id="download">
				<h2>Get TypeMark</h2>
				<p class="lede">
					Free and open source, built with Electron. Currently macOS (Apple Silicon &amp; Intel).
				</p>
				<a class="button button-primary button-large" href={RELEASES}>Download the latest release</a>
				<p class="fine-print">
					Unsigned build — on first launch, right-click the app and choose <strong>Open</strong> to
					bypass Gatekeeper. See the <a href={`${REPO}#readme`}>README</a> for details.
				</p>
			</section>
		</main>

		<footer class="footer">
			<span>TypeMark — MIT licensed.</span>
			<a href={REPO}>Source on GitHub</a>
		</footer>
	</body>
</html>

<style>
	:root {
		--bg: #0d0f0e;
		--bg-raised: #141716;
		--line: rgba(230, 230, 224, 0.1);
		--text: #e9e8e2;
		--text-muted: #9a9a92;
		--accent: #4fb3a9;
		--accent-strong: #6fcbc1;
		--mono: "JetBrains Mono", "SF Mono", Menlo, monospace;
		--serif: "IBM Plex Serif", Georgia, serif;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background: var(--bg);
		color: var(--text);
		font-family: -apple-system, BlinkMacSystemFont, "Inter", system-ui, sans-serif;
		-webkit-font-smoothing: antialiased;
	}

	a {
		color: inherit;
	}

	.nav {
		position: sticky;
		top: 0;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 18px clamp(20px, 6vw, 64px);
		background: rgba(13, 15, 14, 0.85);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--line);
	}

	.nav-brand {
		display: flex;
		align-items: center;
		gap: 8px;
		font-weight: 600;
		font-size: 15px;
		text-decoration: none;
	}

	.nav-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
		border-radius: 6px;
		background: var(--accent);
		color: #06201d;
		font-family: var(--mono);
		font-size: 12px;
		font-weight: 700;
	}

	.nav-links {
		display: flex;
		gap: 28px;
		font-size: 14px;
	}

	.nav-links a {
		text-decoration: none;
		color: var(--text-muted);
	}

	.nav-links a:hover {
		color: var(--text);
	}

	main {
		max-width: 980px;
		margin: 0 auto;
		padding: 0 clamp(20px, 6vw, 64px);
	}

	.hero {
		padding: clamp(48px, 10vw, 96px) 0 clamp(40px, 8vw, 72px);
		text-align: center;
	}

	.eyebrow {
		font-family: var(--mono);
		font-size: 12px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent-strong);
		margin: 0 0 18px;
	}

	h1 {
		font-family: var(--serif);
		font-size: clamp(34px, 6vw, 56px);
		line-height: 1.12;
		margin: 0 auto 20px;
		max-width: 16ch;
	}

	h1 em {
		color: var(--accent-strong);
		font-style: normal;
	}

	.lede {
		font-size: clamp(16px, 2.2vw, 19px);
		line-height: 1.6;
		color: var(--text-muted);
		max-width: 52ch;
		margin: 0 auto 36px;
	}

	.cta-row {
		display: flex;
		gap: 14px;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 56px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 12px 22px;
		border-radius: 9px;
		font-size: 15px;
		font-weight: 600;
		text-decoration: none;
		border: 1px solid transparent;
	}

	.button-primary {
		background: var(--accent);
		color: #06201d;
	}

	.button-primary:hover {
		background: var(--accent-strong);
	}

	.button-ghost {
		border-color: var(--line);
		color: var(--text);
	}

	.button-ghost:hover {
		border-color: var(--accent);
	}

	.button-large {
		padding: 14px 28px;
		font-size: 16px;
	}

	.mockup {
		text-align: left;
		border-radius: 14px;
		overflow: hidden;
		border: 1px solid var(--line);
		background: var(--bg-raised);
		box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45);
	}

	.mockup-titlebar {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 10px 14px;
		border-bottom: 1px solid var(--line);
	}

	.dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
	}

	.dot-red {
		background: #ff5f56;
	}

	.dot-yellow {
		background: #ffbd2e;
	}

	.dot-green {
		background: #27c93f;
	}

	.mockup-path {
		margin-left: 8px;
		font-family: var(--mono);
		font-size: 12px;
		color: var(--text-muted);
	}

	.mockup-body {
		display: grid;
		grid-template-columns: 1.3fr 1fr;
	}

	.mockup-editor {
		padding: 22px 24px;
		font-family: var(--serif);
		font-size: 14px;
		line-height: 1.9;
		border-right: 1px solid var(--line);
	}

	.mockup-editor p {
		margin: 0;
	}

	.mockup-h1 {
		font-weight: 700;
		font-size: 17px;
		margin-bottom: 6px !important;
	}

	.mockup-cursor {
		background: rgba(79, 179, 169, 0.22);
		border-radius: 3px;
		padding: 0 2px;
	}

	.mockup-terminal {
		padding: 22px 20px;
		font-family: var(--mono);
		font-size: 12.5px;
		line-height: 1.8;
		background: #0a0c0b;
	}

	.mockup-terminal p {
		margin: 0;
	}

	.mockup-prompt {
		color: var(--accent-strong);
	}

	.mockup-dim {
		color: var(--text-muted);
	}

	.mockup-blink {
		animation: blink 1.1s steps(1) infinite;
	}

	@keyframes blink {
		50% {
			opacity: 0;
		}
	}

	.features {
		padding: clamp(40px, 8vw, 72px) 0;
		border-top: 1px solid var(--line);
	}

	.features h2,
	.download h2 {
		font-family: var(--serif);
		font-size: clamp(24px, 3.5vw, 32px);
		text-align: center;
		margin: 0 0 40px;
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 20px;
	}

	.feature-card {
		padding: 22px;
		border: 1px solid var(--line);
		border-radius: 12px;
		background: var(--bg-raised);
	}

	.feature-card h3 {
		font-size: 15px;
		margin: 0 0 8px;
	}

	.feature-card p {
		font-size: 14px;
		line-height: 1.6;
		color: var(--text-muted);
		margin: 0;
	}

	.download {
		padding: clamp(48px, 9vw, 80px) 0;
		text-align: center;
		border-top: 1px solid var(--line);
	}

	.download .lede {
		margin-bottom: 28px;
	}

	.fine-print {
		margin-top: 20px;
		font-size: 13px;
		color: var(--text-muted);
	}

	.fine-print a {
		color: var(--accent-strong);
		text-decoration: underline;
	}

	.footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 24px clamp(20px, 6vw, 64px) 40px;
		max-width: 980px;
		margin: 0 auto;
		font-size: 13px;
		color: var(--text-muted);
		border-top: 1px solid var(--line);
	}

	.footer a {
		text-decoration: underline;
	}

	@media (max-width: 640px) {
		.mockup-body {
			grid-template-columns: 1fr;
		}

		.mockup-editor {
			border-right: none;
			border-bottom: 1px solid var(--line);
		}

		.nav-links {
			gap: 16px;
		}
	}
</style>
