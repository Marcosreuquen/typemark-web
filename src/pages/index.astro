---
// No public source repo yet — release binaries are published to a
// separate, code-free repo dedicated to distribution. See web/README.md.
const RELEASES = 'https://github.com/Marcosreuquen/typemark-releases/releases/latest';

// Deployed under a GitHub Pages project base (see astro.config.mjs) — public/
// assets referenced by a literal string need this prefix or they 404 once live.
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const asset = (path: string) => `${base}/${path.replace(/^\/+/, '')}`;

const features = [
  {
    title: 'Live, WYSIWYG markdown',
    body: 'Milkdown/ProseMirror render your formatting as you type — because the prompt and the spec deserve better than a plain text file.',
  },
  {
    title: 'An agent lives in your editor',
    body: 'A real integrated terminal, backed by a native shell. Run Claude Code or any other CLI agent next to the note it’s working on.',
  },
  {
    title: 'Vim mode, done properly',
    body: 'Normal / Insert / Visual, hjkl, word and block motions, yank/delete/paste, and your own custom keymaps.',
  },
  {
    title: 'Git without leaving the page',
    body: 'Stage, commit, and switch branches — including inside nested repos and submodules — from a panel in the status bar.',
  },
  {
    title: 'Private by default, when you want it',
    body: 'Touch ID-locked vaults and notes, encrypted at rest with the OS keychain — not a cloud account.',
  },
  {
    title: 'Tuned for long writing sessions',
    body: 'Eleven themes, ten fonts, adjustable size, wide-block mode for tables and diagrams.',
  },
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href={asset('favicon.svg')} type="image/svg+xml" />
		<title>TypeMark — the IDE for the agentic era</title>
		<meta
			name="description"
			content="Developers don't write every line anymore — they write the prompts, specs, and skills that steer the agents who do. That's markdown, not code. TypeMark is the editor built for it."
		/>
		<meta property="og:title" content="TypeMark — the IDE for the agentic era" />
		<meta
			property="og:description"
			content="The markdown editor for developers who write the agents, not the code."
		/>
		<meta property="og:type" content="website" />
		<meta name="generator" content={Astro.generator} />
	</head>
	<body>
		<header class="nav">
			<a class="nav-brand" href="#top">
				<span class="nav-mark">T</span>
				TypeMark
			</a>
			<nav class="nav-links">
				<a href="#features">Features</a>
				<a class="nav-cta" href={RELEASES}>Download</a>
			</nav>
		</header>

		<main>
			<section class="hero" id="top">
				<p class="eyebrow">For macOS</p>
				<h1>The IDE for the <em>agentic era</em>.</h1>
				<p class="lede">
					You don't write every line anymore — you write the agents that do.
					TypeMark is the editor built for that shift.
				</p>
				<div class="cta-row">
					<a class="button button-primary" href={RELEASES}>Download for Mac</a>
				</div>

				<div class="mockup" aria-label="TypeMark demo">
					<img src={asset('demo.gif')} alt="TypeMark demo" width="960" height="540" />
				</div>
			</section>

			<section class="thesis">
				<h2>Code stopped being the artifact.</h2>
				<p class="lede">
					The actual work now is the prompt, the spec, the skill file that tells an
					agent what to build — and hands it the context to build it right.
					That's not code. It's markdown.
				</p>
				<div class="thesis-flow">
					<span>You</span>
					<span class="thesis-arrow">&rarr;</span>
					<span class="thesis-highlight">Markdown<br /><small>prompts &middot; specs &middot; skills</small></span>
					<span class="thesis-arrow">&rarr;</span>
					<span>Agent</span>
					<span class="thesis-arrow">&rarr;</span>
					<span>Code</span>
				</div>
				<p class="lede">
					TypeMark treats that markdown like the first-class artifact it's become —
					live-rendered, Git-tracked, with the agent's own terminal sitting right next to it.
				</p>
			</section>

			<section class="features" id="features">
				<h2>Everything a writing tool needs. Nothing it doesn't.</h2>
				<div class="feature-grid">
					{features.map((f) => (
						<article class="feature-card">
							<h3>{f.title}</h3>
							<p>{f.body}</p>
						</article>
					))}
				</div>
			</section>

			<section class="download" id="download">
				<h2>Get TypeMark</h2>
				<p class="lede">Currently macOS (Apple Silicon &amp; Intel).</p>
				<a class="button button-primary button-large" href={RELEASES}>Download the latest release</a>
				<p class="fine-print">
					The first time you open it, right-click the app and choose <strong>Open</strong> — it isn't
					notarized by Apple yet, so Gatekeeper needs that one confirmation.
				</p>
			</section>
		</main>

		<footer class="footer">
			<span>TypeMark © 2026</span>
		</footer>
	</body>
</html>

<style>
	:root {
		--bg: #191919;
		--bg-soft: #222222;
		--bg-raised: rgba(25, 25, 25, 0.97);
		--line: rgba(255, 255, 255, 0.11);
		--state: rgba(255, 255, 255, 0.08);
		--text: #e9e8e4;
		--text-strong: #ffffff;
		--text-muted: #aaa8a4;
		--text-muted-soft: #8d8b87;
		--accent: #7db7ff;
		--accent-strong: #a9cffc;
		--mono: "JetBrains Mono", "SF Mono", Menlo, monospace;
		--serif: "IBM Plex Serif", Georgia, serif;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background: var(--bg);
		color: var(--text);
		font-family: -apple-system, BlinkMacSystemFont, "Inter", system-ui, sans-serif;
		-webkit-font-smoothing: antialiased;
	}

	a {
		color: inherit;
	}

	.nav {
		position: sticky;
		top: 0;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 18px clamp(20px, 6vw, 64px);
		background: rgba(25, 25, 25, 0.85);
		backdrop-filter: blur(10px);
		border-bottom: 1px solid var(--line);
	}

	.nav-brand {
		display: flex;
		align-items: center;
		gap: 8px;
		font-weight: 600;
		font-size: 15px;
		text-decoration: none;
		color: var(--text-strong);
	}

	.nav-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
		border-radius: 6px;
		background: var(--accent);
		color: #0d1a26;
		font-family: var(--mono);
		font-size: 12px;
		font-weight: 700;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 24px;
		font-size: 14px;
	}

	.nav-links a {
		text-decoration: none;
		color: var(--text-muted);
	}

	.nav-links a:hover {
		color: var(--text);
	}

	.nav-cta {
		padding: 7px 14px;
		border-radius: 7px;
		background: var(--accent);
		color: #0d1a26 !important;
		font-weight: 600;
	}

	.nav-cta:hover {
		background: var(--accent-strong);
	}

	main {
		max-width: 980px;
		margin: 0 auto;
		padding: 0 clamp(20px, 6vw, 64px);
	}

	.hero {
		padding: clamp(48px, 10vw, 96px) 0 clamp(40px, 8vw, 72px);
		text-align: center;
	}

	.eyebrow {
		font-family: var(--mono);
		font-size: 12px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent-strong);
		margin: 0 0 18px;
	}

	h1 {
		font-family: var(--serif);
		color: var(--text-strong);
		font-size: clamp(34px, 6vw, 56px);
		line-height: 1.12;
		margin: 0 auto 20px;
		max-width: 16ch;
	}

	h1 em {
		color: var(--accent-strong);
		font-style: normal;
	}

	.lede {
		font-size: clamp(16px, 2.2vw, 19px);
		line-height: 1.6;
		color: var(--text-muted);
		max-width: 52ch;
		margin: 0 auto 36px;
	}

	.cta-row {
		display: flex;
		gap: 14px;
		justify-content: center;
		flex-wrap: wrap;
		margin-bottom: 56px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 12px 22px;
		border-radius: 9px;
		font-size: 15px;
		font-weight: 600;
		text-decoration: none;
		border: 1px solid transparent;
	}

	.button-primary {
		background: var(--accent);
		color: #0d1a26;
	}

	.button-primary:hover {
		background: var(--accent-strong);
	}

	.button-large {
		padding: 14px 28px;
		font-size: 16px;
	}

	.mockup {
		/* The screenshot/recording already has its own window chrome (traffic
		   lights, rounded corners) — no extra border or frame here, just a
		   soft shadow for depth, or it reads as a frame around a frame. */
		line-height: 0;
		filter: drop-shadow(0 25px 60px rgba(0, 0, 0, 0.5));
	}

	.mockup img {
		display: block;
		width: 100%;
		height: auto;
	}

	.thesis {
		padding: clamp(48px, 9vw, 80px) 0;
		border-top: 1px solid var(--line);
		text-align: center;
	}

	.thesis h2 {
		font-family: var(--serif);
		color: var(--text-strong);
		font-size: clamp(26px, 4vw, 36px);
		margin: 0 0 20px;
	}

	.thesis .lede:last-of-type {
		margin-bottom: 0;
	}

	.thesis-flow {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 14px;
		margin: 8px auto 32px;
		font-size: 15px;
		color: var(--text-muted);
	}

	.thesis-arrow {
		color: var(--text-muted-soft);
		font-size: 18px;
	}

	.thesis-highlight {
		padding: 10px 18px;
		border-radius: 10px;
		background: var(--bg-soft);
		border: 1px solid var(--line);
		color: var(--accent-strong);
		font-family: var(--mono);
		font-weight: 600;
		font-size: 14px;
		line-height: 1.5;
	}

	.thesis-highlight small {
		display: block;
		color: var(--text-muted);
		font-weight: 400;
		font-size: 11px;
		letter-spacing: 0.02em;
	}

	.features {
		padding: clamp(40px, 8vw, 72px) 0;
		border-top: 1px solid var(--line);
	}

	.features h2,
	.download h2 {
		font-family: var(--serif);
		color: var(--text-strong);
		font-size: clamp(24px, 3.5vw, 32px);
		text-align: center;
		margin: 0 0 40px;
	}

	.feature-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 20px;
	}

	.feature-card {
		padding: 22px;
		border: 1px solid var(--line);
		border-radius: 12px;
		background: var(--bg-soft);
	}

	.feature-card h3 {
		font-size: 15px;
		color: var(--text-strong);
		margin: 0 0 8px;
	}

	.feature-card p {
		font-size: 14px;
		line-height: 1.6;
		color: var(--text-muted);
		margin: 0;
	}

	.download {
		padding: clamp(48px, 9vw, 80px) 0;
		text-align: center;
		border-top: 1px solid var(--line);
	}

	.download .lede {
		margin-bottom: 28px;
	}

	.fine-print {
		margin-top: 20px;
		font-size: 13px;
		color: var(--text-muted-soft);
		max-width: 44ch;
		margin-inline: auto;
	}

	.footer {
		padding: 24px clamp(20px, 6vw, 64px) 40px;
		max-width: 980px;
		margin: 0 auto;
		font-size: 13px;
		color: var(--text-muted-soft);
		border-top: 1px solid var(--line);
	}

	@media (max-width: 640px) {
		.nav-links {
			gap: 14px;
		}
	}
</style>
